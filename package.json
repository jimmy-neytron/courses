{
  "name": "courses-nuxt-green-preview-restored",
  "private": true,
  "version": "0.9.0",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit -p tsconfig.app.json && vite build",
    "typecheck": "vue-tsc --noEmit -p tsconfig.app.json",
    "preview": "vite preview",
    "verify": "node scripts/verify-project.mjs && node scripts/check-architecture.mjs && node scripts/check-styles.mjs && node scripts/check-typescript-syntax.mjs",
    "check:architecture": "node scripts/check-architecture.mjs",
    "check:styles": "node scripts/check-styles.mjs"
  },
  "dependencies": {
    "@neytron/compact-ui": "0.3.0",
    "@supabase/supabase-js": "^2.110.7",
    "lucide-vue-next": "^0.468.0",
    "pinia": "^3.0.3",
    "vue": "^3.5.17",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@vitejs/plugin-vue": "^6.0.1",
    "typescript": "~5.8.3",
    "vite": "^7.0.6",
    "vue-tsc": "^3.0.4"
  }
}
